---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import "../style/style.css";
---

<Layout title="About">
    <Header active="about" />

    <section class="sec1">
        <h3>About me</h3>

        <div class="card hide1">
            <p>
                I'm currently a secondary school student in Kraków, Poland. I
                also attend an AI course at the Jagiellonian University. My
                dream is to become a software developer.
                <input type="checkbox" id="toggle" hidden />
                <label for="toggle">Read More</label>
            </p>
        </div>

        <div class="card hide2">
            <p>
                I'm interested in various types of programming languages C#,
                Python and web development.
            </p>
        </div>

        <div class="card blog">
            <p>
                Lorem ipsum dolor sit amet consectetur adipisicing elit. Totam
                commodi sit soluta voluptatem vel hic molestias adipisci
                officiis, veniam unde perspiciatis, quis ea inventore
                consequatur. Velit, ullam. Ab, nemo repellat? Lorem, ipsum dolor
                sit amet consectetur adipisicing elit. Error provident omnis
                dolor quis, quisquam voluptatum officiis, cumque est nobis eaque
                aut. Tempore tempora, officia quia eaque et odio dolores libero!
                Lorem ipsum dolor sit amet consectetur adipisicing elit.
                Corrupti, rerum repellat doloribus quam molestiae facere eveniet
                eligendi at reprehenderit aliquid optio nesciunt, officiis
                beatae magni impedit ea dolorum ullam quis. Lorem ipsum, dolor
                sit amet consectetur adipisicing elit. Odit unde sequi
                architecto ex sapiente, nostrum et repudiandae autem sint
                provident ullam enim repellendus esse officiis aliquam deserunt
                mollitia soluta similique!
                <input type="checkbox" id="toggleBack" hidden />
                <label for="toggleBack">Go back</label>
            </p>
        </div>
    </section>

    <script>
        const toggle = document.getElementById("toggle");
        const toggleBack = document.getElementById("toggleBack");
        const blog = document.querySelector(".blog");
        const card1 = document.querySelector(".hide1");
        const card2 = document.querySelector(".hide2");

        function showBlog() {
            blog.style.display = "block";
            card1.style.display = "none";
            card2.style.display = "none";
        }

        function showCards() {
            blog.style.display = "none";
            card1.style.display = "block";
            card2.style.display = "block";
            toggle.checked = false;
        }

        toggle?.addEventListener("change", showBlog);
        toggleBack?.addEventListener("change", showCards);
    </script>
</Layout>
